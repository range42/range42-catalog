# ── MISP build / version ──────────────────────────────────────────────────────
MISP_VERSION=v2.5.37

# ── Network ───────────────────────────────────────────────────────────────────
# Port on the Docker host that MISP's HTTP interface binds to
MISP_PORT=8080

# Base URL that MISP advertises in events, feeds, and e-mails.
# Change to your real hostname or IP when deploying beyond localhost.
MISP_BASEURL=http://localhost:8080

# ── Organisation ──────────────────────────────────────────────────────────────
MISP_ORG=Default Organisation

# ── Security salt ─────────────────────────────────────────────────────────────
# Must be a long random string. Rotate and rebuild if compromised.
# Generate one: openssl rand -hex 32
MISP_SALT=changeme_replace_with_openssl_rand_hex_32

# ── MariaDB ───────────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=3306
MISP_DB_NAME=misp
MISP_DB_USER=misp
MISP_DB_PASSWORD=changeme_db_password
DB_ROOT_PASSWORD=changeme_db_root_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Admin user (primary) ──────────────────────────────────────────────────────
# cake userInit creates admin@admin.test on first boot; the entrypoint then
# changes the e-mail and password to the values below.
# Passwords must be ≥ 12 characters (MISP default policy).
MISP_ADMIN_EMAIL=admin@misp.local
MISP_ADMIN_PASSWORD=Admin1234!XYZ

# ── Admin user (secondary, optional) ─────────────────────────────────────────
# Leave both blank to skip creation of a second admin account.
MISP_ADMIN2_EMAIL=
MISP_ADMIN2_PASSWORD=

# ── Reader user (MISP role: Read Only, role_id=5) ────────────────────────────
MISP_READER_EMAIL=reader@misp.local
MISP_READER_PASSWORD=Reader1234!XYZ

# ── Writer user (MISP role: Publisher, role_id=4) ────────────────────────────
MISP_WRITER_EMAIL=writer@misp.local
MISP_WRITER_PASSWORD=Writer1234!XYZ
