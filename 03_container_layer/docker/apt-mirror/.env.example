# Copy to .env and adjust for your deployment.
# The Ansible role (software.install.apt_mirror_server) renders this automatically.

ACNG_PORT=3142
NGINX_PORT=80

# Named volume — set by apt_mirror_persistent var.
# When apt_mirror_persistent=false the role uses an anonymous volume (wiped on removal).
CACHE_VOLUME_NAME=apt-mirror-cache
